{
  "name": "pro-studio",
  "private": true,
  "description": "Pro Studio - Advanced Media Editing Suite",
  "author": "GR Studios",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:start": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder",
    "build:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.grstudios.prostudio",
    "productName": "Pro Studio",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "fileAssociations": [
      {
        "ext": [
          "gif"
        ],
        "name": "GIF Animation",
        "description": "GR Studios GIF File"
      },
      {
        "ext": [
          "png",
          "jpg",
          "jpeg",
          "webp"
        ],
        "name": "Image File",
        "description": "GR Studios Image File"
      },
      {
        "ext": [
          "mp4",
          "mkv",
          "avi",
          "mov"
        ],
        "name": "Video File",
        "description": "GR Studios Video File"
      },
      {
        "ext": [
          "mp3",
          "wav",
          "flac"
        ],
        "name": "Audio File",
        "description": "GR Studios Audio File"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "src/**/*"
    ]
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cropperjs": "^1.6.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gif.js": "^0.2.0",
    "gifuct-js": "^2.1.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
